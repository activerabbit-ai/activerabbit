<%# Top-of-page quota exceeded banner. Dismissible; close persists in localStorage (quota-notification controller). %>
<% if current_account && @quota_exceeded_message.present? %>
  <div class="bg-red-50 border-l-4 border-red-400 p-4 mx-6 mt-4 rounded-r-lg"
       data-controller="quota-notification"
       data-quota-notification-account-id-value="<%= current_account.id %>">
    <div class="flex items-start gap-3">
      <svg class="h-5 w-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.268 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
      </svg>
      <div class="flex-1 min-w-0">
        <p class="text-sm text-red-700"><%= @quota_exceeded_message %></p>
        <%= link_to "View plan", plan_path, class: "inline-block mt-1 text-sm font-medium text-red-600 hover:text-red-800 underline" %>
      </div>
      <button type="button"
              data-action="click->quota-notification#dismiss"
              class="flex-shrink-0 p-1.5 rounded text-red-500 hover:bg-red-100 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-400"
              aria-label="Close">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
<% end %>
