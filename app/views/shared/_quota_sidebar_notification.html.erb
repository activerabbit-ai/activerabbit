<%# Only show when account has exceeded resources (level == :exceeded). Dismissal is persisted in localStorage via quota-notification controller. %>
<% if current_account && current_account.resources_with_warnings.any? { |w| w[:level] == :exceeded } %>
  <% message = current_account.quota_exceeded_flash_message %>
  <% if message.present? %>
    <div class="mb-3 p-3 rounded-lg bg-red-50 border border-red-200"
         data-controller="quota-notification"
         data-quota-notification-account-id-value="<%= current_account.id %>"
         data-sidebar-target="quotaBox">
      <div class="flex items-start justify-between gap-2">
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-red-800">
            <%= message %>
          </p>
          <%= link_to "View plan", plan_path, class: "mt-2 inline-block text-xs font-medium text-red-600 hover:text-red-800 underline" %>
        </div>
        <button type="button"
                data-action="click->quota-notification#dismiss"
                class="flex-shrink-0 p-1 rounded text-red-500 hover:bg-red-100 hover:text-red-700 focus:outline-none focus:ring-1 focus:ring-red-400"
                aria-label="Close">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  <% end %>
<% end %>
